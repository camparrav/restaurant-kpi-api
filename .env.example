# Server
PORT=3001
WEBHOOK_SECRET=change-this-secret

# Anthropic API (required for /api/analyze, /api/brief, and the inbox monitor)
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Outlook / Microsoft 365 inbox monitor
# ---------------------------------------------------------------------------
# Setup (one-time):
#   1. https://portal.azure.com -> Azure AD -> App registrations -> New registration
#      - Name: "Inbox Monitor"
#      - Account types: "Accounts in any org directory AND personal Microsoft accounts"
#      - Redirect URI: leave blank
#   2. In the new app -> Authentication -> "Allow public client flows" = YES
#   3. API permissions -> Add -> Microsoft Graph -> Delegated:
#        Mail.ReadWrite, offline_access, User.Read
#      Then click "Grant admin consent" if it's a work account.
#   4. Copy "Application (client) ID" into OUTLOOK_CLIENT_ID below.
#   5. Run: npm run connect-outlook
#      Open the printed URL, paste the code, sign in. A refresh token is saved
#      to .outlook-token.json (gitignored). The monitor uses it from then on.
#
# When MONITOR_ENABLED=true and the server starts, it polls the inbox every
# MONITOR_INTERVAL_MS and saves AI-drafted replies to your Outlook Drafts folder.
# Nothing is sent automatically — you review and click Send.
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT=common
MONITOR_ENABLED=false
MONITOR_INTERVAL_MS=60000
MONITOR_CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional safety filters (comma-separated email addresses, case-insensitive).
# If MONITOR_ALLOW_LIST is set, ONLY messages from those senders get drafts.
MONITOR_ALLOW_LIST=
MONITOR_BLOCK_LIST=
